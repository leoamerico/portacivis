{
  "name": "portacivis-portal",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "gen:brand-registry": "node scripts/gen-brand-registry.mjs",
    "verify:brand": "node scripts/verify-brand-governance.mjs && node scripts/verify-no-hardcoded-brand-colors.mjs",
    "typecheck": "tsc --noEmit",
    "build": "npm run gen:brand-registry && npm run verify:brand && next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "governance:verify": "node scripts/verify-operational-governance.mjs",
    "security:headers": "node scripts/verify-security-headers.mjs",
    "security:verify": "bun run governance:verify && bun run security:headers && bun run test:i18n && bun run build",
    "test:smoke": "node scripts/smoke-domain.mjs",
    "test:truth-trail": "node scripts/smoke-truth-trail.mjs",
    "test:amparo": "node scripts/smoke-amparo-validation.mjs",
    "test:i18n": "node scripts/verify-i18n-smoke.mjs",
    "verify:all": "bun run security:verify && bun run test:smoke",
    "new-adr": "bun run scripts/new-adr.ts"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "next": "15.5.12",
    "next-intl": "^4.8.3",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "eslint": "^8.56.0",
    "eslint-config-next": "^15.5.12",
    "typescript": "^5.3.3",
    "yaml": "^2.8.1"
  }
}
